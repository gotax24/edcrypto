# Ignorar scripts de instalación (prevenir ejecución de código de terceros)
ignore-scripts=true

# Forzar la versión exacta de Node.js especificada en package.json
engine-strict=true

# Guardar versiones exactas de dependencias (sin ^ ni ~)
save-exact=true

# Fallar si hay incompatibilidad de dependencias pares (peer dependencies)
strict-peer-dependencies=true

# Priorizar la caché local antes de descargar de internet
prefer-offline=true

# Verificar que los paquetes en caché no estén corruptos
verify-store-integrity=true

# Tolerancia a fallos de red (reintentos y tiempos de espera)
fetch-retries=3
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=120000